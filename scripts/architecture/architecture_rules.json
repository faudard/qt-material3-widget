{
  "schema_version": 1,
  "layer_rules": [
    {
      "name": "foundation-is-dependency-free",
      "paths": [
        "include/qtmaterial/foundation",
        "src/foundation"
      ],
      "forbidden_include_prefixes": [
        "qtmaterial/theme/",
        "qtmaterial/specs/",
        "qtmaterial/core/",
        "qtmaterial/effects/",
        "qtmaterial/widgets/"
      ],
      "forbidden_includes": [
        "QWidget",
        "QApplication",
        "QStyle",
        "QAbstractButton"
      ]
    },
    {
      "name": "theme-does-not-depend-on-runtime-layers",
      "paths": [
        "include/qtmaterial/theme",
        "src/theme"
      ],
      "forbidden_include_prefixes": [
        "qtmaterial/core/",
        "qtmaterial/specs/",
        "qtmaterial/effects/",
        "qtmaterial/widgets/"
      ],
      "forbidden_includes": [
        "QWidget",
        "QApplication",
        "QAbstractButton"
      ]
    },
    {
      "name": "specs-do-not-depend-on-widget-runtime",
      "paths": [
        "include/qtmaterial/specs",
        "src/specs"
      ],
      "forbidden_include_prefixes": [
        "qtmaterial/core/",
        "qtmaterial/effects/",
        "qtmaterial/widgets/"
      ],
      "forbidden_includes": [
        "QWidget",
        "QApplication",
        "QStyle",
        "QAbstractButton",
        "QLineEdit",
        "QDialog",
        "QMainWindow"
      ]
    },
    {
      "name": "tooling-does-not-depend-on-runtime-layers",
      "paths": [
        "include/qtmaterial/tooling",
        "src/tooling"
      ],
      "forbidden_include_prefixes": [
        "qtmaterial/theme/",
        "qtmaterial/specs/",
        "qtmaterial/core/",
        "qtmaterial/integration/",
        "qtmaterial/effects/",
        "qtmaterial/widgets/"
      ],
      "forbidden_includes": [
        "QWidget",
        "QApplication",
        "QAbstractButton",
        "QPalette"
      ]
    },
    {
      "name": "integration-does-not-depend-on-runtime-layers",
      "paths": [
        "include/qtmaterial/integration",
        "src/integration"
      ],
      "forbidden_include_prefixes": [
        "qtmaterial/specs/",
        "qtmaterial/core/",
        "qtmaterial/tooling/",
        "qtmaterial/effects/",
        "qtmaterial/widgets/"
      ],
      "forbidden_includes": [
        "QWidget",
        "QApplication",
        "QAbstractButton"
      ]
    }
  ],
